{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sable",
  "version": "0.1.0",
  "identifier": "com.sable.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sable",
        "width": 1200,
        "height": 750,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.sable.app/update/{{target}}/{{arch}}/{{current_version}}"],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCQUM2MDg0OTc5NDQ0OTUKUldTVlJKU1hoR0NzTzNuVEQvWmlsNnh5S2xTSDhVa3YyeWVvSWdBdW5mS0M2NnlERkFtaEw3M3AK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": ["binaries/sable-service", "binaries/sable-overlay"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
